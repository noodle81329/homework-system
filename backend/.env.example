# 後端 JWT 簽章密鑰 (可自訂)
JWT_SECRET_KEY=your-super-secret-jwt-key

# 擔任教師身分的 Google 帳號 Email (可傳入多個，以逗號分隔)
TEACHER_EMAILS=teacher@example.com,admin@example.com

# 若使用 Google Drive API 上傳，請將下載的服務帳戶 JSON 憑證命名為 `service-account.json` 放在 backend 資料夾中
# 預設會讀取 service-account.json，若路徑不同可透過此變數指定
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# 用於驗證前端傳來的 Google Token 合法性，需要與前端的 Client ID 相同
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
